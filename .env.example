# Copy this file to .env and fill in real values. .env is gitignored and is
# what docker-compose.yml loads via `env_file`.

# Required — read directly by db/supabase.ts
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ROLE_KEY=your-supabase-service-role-key

# Currently unused by the app, but present in some environments' .env.
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
CODEFORCES_KEY=
CODEFORCES_SECRET=

# Optional — cron schedule for the recurring "refresh all users" job.
# Standard 5-field cron syntax. Defaults to every 3 hours if unset.
REFRESH_CRON_SCHEDULE=0 */3 * * *

# Optional — host port to publish via docker-compose (container always listens on 5000).
WORKER_PORT=5000
